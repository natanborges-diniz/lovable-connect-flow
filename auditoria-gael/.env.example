# ─────────────────────────────────────────────────────────────────────────────
# AUDITORIA GAEL — Variáveis de ambiente
#
# ATENÇÃO: copie este arquivo como .env e preencha os valores reais.
# O arquivo .env NUNCA deve ser commitado (já está no .gitignore).
# A service_role key dá acesso TOTAL ao banco — trate como senha root.
# ─────────────────────────────────────────────────────────────────────────────

# URL do projeto Supabase (ex: https://xxxxxxxx.supabase.co)
SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co

# Chave service_role — encontre em:
# Supabase Dashboard → Project Settings → API → service_role (secret)
# NUNCA compartilhe nem commite este valor.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.PLACEHOLDER

# Connection string PostgreSQL direta (para as queries SQL complexas via pg)
# Formato: postgresql://postgres:[DB_PASSWORD]@db.SEU_PROJECT_REF.supabase.co:5432/postgres
# Encontre em: Supabase Dashboard → Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:SUA_SENHA@db.SEU_PROJECT_REF.supabase.co:5432/postgres
